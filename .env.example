# MongoDB Connection
# Set your MongoDB Atlas URI. If left blank or invalid, the backend automatically 
# falls back to a local JSON-based mock database for complete offline functionality.
MONGO_URI=

# Authentication
JWT_SECRET=change-me-before-deploy
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Configuration (Provide Groq key or OpenAI key. If both are empty, simulation mode is activated)
GROQ_API_KEY=
OPENAI_API_KEY=

# Hindsight Memory (required for real-SDK memory features)
# Option A — self-host via Docker, no signup needed (see README for the docker run command)
#   HINDSIGHT_BASE_URL=http://localhost:8888
#   HINDSIGHT_API_KEY=            # blank for local self-host, no auth required
#
# Option B — Hindsight Cloud (https://ui.hindsight.vectorize.io/signup)
#   HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
#   HINDSIGHT_API_KEY=<key from the Connect page>
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_API_KEY=
HINDSIGHT_BANK_ID=incidents

# Server Config
HOST=127.0.0.1
PORT=8000
